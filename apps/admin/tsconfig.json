{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@repo/config-typescript/nextjs.json",
  "compilerOptions": {
    "outDir": ".next",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
