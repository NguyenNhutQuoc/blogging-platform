# App
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
ADMIN_URL=http://localhost:3002

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blog_platform
DATABASE_TEST_URL=postgresql://postgres:postgres@localhost:5433/blog_platform_test

# Redis (shared: cache + BullMQ + rate limiting)
REDIS_URL=redis://localhost:6379

# Auth (Better Auth)
BETTER_AUTH_SECRET=change-me-in-production-min-32-chars
BETTER_AUTH_URL=http://localhost:3001/api/v1/auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe (Phase 3+ — not needed for MVP)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# S3 / MinIO (local dev: MinIO; production: Cloudflare R2 or AWS S3)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=blog-media
S3_PUBLIC_URL=http://localhost:9000/blog-media

# Email (Resend)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# CORS — comma-separated list of allowed frontend origins
# In production: set to your exact domain(s), no trailing slash
CORS_ORIGINS=http://localhost:3000,http://localhost:3002

# Analytics
ANALYTICS_SALT=change-me-random-salt-for-visitor-hashing

# Meilisearch (Phase 5+ — NOT needed for MVP, use PostgreSQL FTS)
# MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_API_KEY=your-master-key
